HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=replace-with-the-api-server-key
CONVEX_URL=https://replace-with-your-deployment.convex.cloud

# Required only when Hermes and FastAPI run in the same deployment container.
OPENAI_API_KEY=replace-with-openai-key
SUPERMEMORY_API_KEY=replace-with-supermemory-key
SUPERMEMORY_CONTAINER_TAG=doable-production
API_SERVER_KEY=replace-with-a-long-random-key
HERMES_MODEL=gpt-5.4

GITHUB_APP_ID=replace-with-github-app-id
GITHUB_APP_SLUG=replace-with-github-app-slug
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem
# Container hosts can provide the PEM contents directly instead of a file path.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CALLBACK_URL=http://127.0.0.1:8787/v1/github/callback
GITHUB_STATE_SECRET=replace-with-a-long-random-secret
